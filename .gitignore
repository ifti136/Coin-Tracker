# =============================================================================
#  Coin Tracker — Root .gitignore
#  Covers: Android (Kotlin/Compose), Flask web, PyQt5 desktop, Firebase
#  Place this file at the repo root and rename it to .gitignore
# =============================================================================


# =============================================================================
#  SECRETS & CREDENTIALS  ← never commit these
# =============================================================================

# Firebase service account keys (all patterns)
firebase-key.json
*firebase-key*.json
serviceAccountKey.json
*serviceAccount*.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json

# Android Firebase config — add your own manually
android/app/google-services.json

# Python environment files
.env
.env.*
.env.local
.env.production
!.env.example

# Private keys and certificates
*.pem
*.key
*.cert
*.p12

# Android signing keystores
*.jks
*.keystore


# =============================================================================
#  ANDROID
# =============================================================================

# Gradle caches and build outputs
android/.gradle/
android/build/
android/app/build/
android/**/build/

# Gradle wrapper JAR (the .properties file IS committed; the jar is not)
android/gradle/wrapper/gradle-wrapper.jar

# Gradle executables (regenerated by wrapper)
android/gradlew
android/gradlew.bat

# Machine-specific local config (SDK path etc.)
android/local.properties

# Android Studio / IntelliJ project files
android/.idea/
android/**/.idea/
android/*.iml
android/.navigation/
android/captures/
android/.externalNativeBuild/
android/.cxx/

# APK / AAB build outputs
android/*.apk
android/*.aab
android/*.ap_
android/*.dex
android/*.class

# KSP generated sources
android/app/build/generated/

# Android profiling snapshots
android/*.hprof


# =============================================================================
#  PYTHON — shared rules for web/ and desktop/
# =============================================================================

# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST
wheels/
sdist/

# PyInstaller spec files and build artefacts
*.spec
*.manifest

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/


# =============================================================================
#  WEB (Flask — web/)
# =============================================================================

# Flask instance folder
web/instance/

# Flask session data
web/flask_session/
flask_session/

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Render deployment artefacts
web/.render/


# =============================================================================
#  DESKTOP (PyQt5 — desktop/)
# =============================================================================

# PyInstaller output
desktop/dist/
desktop/build/
desktop/*.spec

# Generated icon file (regenerate with coin_icon.py)
desktop/coin.ico
desktop/coin.icns


# =============================================================================
#  FIREBASE / GOOGLE CLOUD
# =============================================================================

# Firebase emulator state and logs
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Hosting deploy cache
.firebaserc


# =============================================================================
#  NODE / NPM (tooling scripts, if any)
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock


# =============================================================================
#  EDITORS & IDEs
# =============================================================================

# JetBrains (IntelliJ, Android Studio, PyCharm)
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn

# Emacs
*~
\#*\#
.emacs.desktop
.emacs.desktop.lock
*.elc

# Eclipse
.classpath
.project
.settings/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/


# =============================================================================
#  OPERATING SYSTEM
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*


# =============================================================================
#  LOGS & TEMP FILES
# =============================================================================

*.log
logs/
*.tmp
*.temp
*.bak
*.orig
*.cache
tmp/
temp/
.history/
*.pid
*.pid.lock
