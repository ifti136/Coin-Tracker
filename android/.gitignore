# ============================================================
#  Coin Tracker — .gitignore
#  Covers: Android (Kotlin/Compose), Python (Flask), Firebase
# ============================================================


# ============================================================
#  SECRETS & CREDENTIALS  ← most important section
# ============================================================

# Firebase config — contains API keys, never commit this
android/app/google-services.json

# Google service account keys (used by Firebase Admin SDK on the backend)
*.json
!android/app/src/main/res/**/*.json   # keep any resource JSON files

# Python environment variables / secrets
.env
.env.*
!.env.example

# Any private key files
*.pem
*.key
*.p12
*.keystore
*.jks


# ============================================================
#  ANDROID
# ============================================================

# Gradle build outputs
android/.gradle/
android/build/
android/app/build/
android/**/build/

# Gradle wrapper jar (the .properties file IS committed, the jar is not)
android/gradle/wrapper/gradle-wrapper.jar

# Local configuration — machine-specific, never shared
android/local.properties

# Android Studio project files
android/.idea/
android/**/.idea/
*.iml
*.ipr
*.iws

# Android Studio captures and profiling
android/captures/
android/.externalNativeBuild/
android/.cxx/

# Keystore files for release signing (keep your signing config out of git)
android/*.jks
android/*.keystore
android/app/*.jks
android/app/*.keystore

# Generated files
android/app/src/main/java/**/BuildConfig.java
android/app/src/main/java/**/R.java

# Navigation args generated sources (safe-args plugin)
android/app/src/main/java/**/directions/
android/app/src/main/java/**/args/

# KSP generated sources
android/app/build/generated/ksp/

# ProGuard mapping (keep if you want to decode crash reports for release builds)
# android/app/mapping.txt

# DS_Store (macOS folder metadata)
**/.DS_Store


# ============================================================
#  PYTHON / FLASK BACKEND (web/)
# ============================================================

# Virtual environments
web/venv/
web/.venv/
web/env/
venv/
.venv/

# Compiled Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
web/dist/
web/build/
web/*.egg-info/
web/.eggs/
*.egg

# Flask session files
flask_session/

# SQLite databases (if used for local dev)
*.db
*.sqlite
*.sqlite3

# Pytest cache
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Celery beat schedule
celerybeat-schedule
celerybeat.pid


# ============================================================
#  FIREBASE / GOOGLE CLOUD
# ============================================================

# Service account credentials
service-account*.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json

# Firebase local emulator data
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Firebase hosting deploy artifacts
.firebaserc
# Note: keep firebase.json if you use Firebase Hosting


# ============================================================
#  NODE / TOOLING (if any scripts use npm)
# ============================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock


# ============================================================
#  EDITOR & OS
# ============================================================

# JetBrains IDEs (IntelliJ, Android Studio, PyCharm)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ============================================================
#  MISC
# ============================================================

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp
*.swp
*.swo

# Backup files created by editors
*.bak
*.orig