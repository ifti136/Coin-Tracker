# =============================================================================
#  android/.gitignore
#  Android-specific ignores. Place this file at android/.gitignore
#  The root .gitignore already covers .idea/, *.jks, google-services.json,
#  and Gradle outputs globally. Only android/-specific additions live here.
# =============================================================================

# Gradle caches and build outputs
.gradle/
build/
app/build/
**/build/

# Machine-specific local config (Android SDK path)
local.properties

# Gradle wrapper JAR (properties file IS committed)
gradle/wrapper/gradle-wrapper.jar

# Gradle executables — regenerated by the wrapper
gradlew
gradlew.bat

# Android Studio / IntelliJ project metadata
.idea/
*.iml
.navigation/
captures/
.externalNativeBuild/
.cxx/

# KSP and kapt generated sources
app/build/generated/

# Firebase Android config — add yours manually
app/google-services.json

# Android signing keystores
*.jks
*.keystore

# Android profiling heap dumps
*.hprof

# Build artefacts
*.apk
*.aab
*.ap_
*.dex
*.class
